GRP_ATR_FILTER = "🥇 ATR 波動收斂過濾"
useAtrFilter = input.bool(false, "啟用 ATR 波動收斂過濾", group=GRP_ATR_FILTER)
atrFilterLen = input.int(14, "ATR 原始長度", minval=1, group=GRP_ATR_FILTER)
