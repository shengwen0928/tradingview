//@version=6
indicator("賽克斯X獵影", overlay=false, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ==========================================
// 總開關 (Project Toggles)
// ==========================================
enable_sykes = input.bool(true, "啟用賽克斯", group="專案總開關")
enable_leain = input.bool(true, "啟用獵影", group="專案總開關")

// ==========================================
// 1. 賽克斯專案參數
// ==========================================
group_struct = "市場結構設定"
lb_len = input.int(5, "結構回看強度 (Left)", minval=1, group=group_struct)
rb_len = input.int(5, "結構確認強度 (Right)", minval=1, group=group_struct)
trend_mode = input.string("Vegas 通道", "趨勢判定模式", options=["市場結構 (HH/LL)", "Vegas 通道"], group=group_struct)
show_labels = input.bool(false, "顯示結構標籤 (HH/LL)", group=group_struct)

group_panel = "面板顯示設定"
show_panel = input.bool(true, "顯示趨勢面板", group=group_panel)
panel_pos  = input.string("Bottom Right", "面板位置", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left", "Top Center", "Bottom Center"], group=group_panel)

group_extra = "自訂時區監控 (手動勾選)"
ex1_en = input.bool(true, "監控 1", inline="ex1", group=group_extra)
ex1_tf = input.timeframe("60", "", inline="ex1", group=group_extra)
ex2_en = input.bool(true, "監控 2", inline="ex2", group=group_extra)
ex2_tf = input.timeframe("240", "", inline="ex2", group=group_extra)
ex3_en = input.bool(true, "監控 3", inline="ex3", group=group_extra)
ex3_tf = input.timeframe("D", "", inline="ex3", group=group_extra)
ex4_en = input.bool(true, "監控 4", inline="ex4", group=group_extra)
ex4_tf = input.timeframe("W", "", inline="ex4", group=group_extra)

group_mtf = "智慧對標開關 (當前對標 HTF)"
en_smart = input.bool(true, "啟用自動對標模式 (LTF -> HTF)", group=group_mtf)
filter_mtf = input.bool(false, "進場需符合對標時區趨勢 (共振過濾)", group=group_mtf)
filter_same_bar = input.bool(true, "過濾單根 K 棒同時完成回測與進場 (防急漲急跌)", group=group_mtf)

group_vegas = "EMA/MA (Vegas Tunnels)"
ema_len1 = input.int(144, "EMA 1 (小通道 1)", group=group_vegas)
ema_len2 = input.int(169, "EMA 2 (小通道 2)", group=group_vegas)
ema_len3 = input.int(576, "EMA 3 (大通道 1)", group=group_vegas)
ema_len4 = input.int(676, "EMA 4 (大通道 2)", group=group_vegas)
ema_len5 = input.int(12, "EMA 5 (過濾線)", group=group_vegas)
ema_fast_len = input.int(7, "EMA 快線 (出場用)", group=group_vegas)
ignore_bars_after_ema_exit = input.int(0, "過濾線收回後忽略 K 棒數", minval=0, group=group_vegas, tooltip="在過濾線（EMA 12）收回到趨勢方向（脫離小通道）後的 N 根 K 棒內禁止進場。")
ignore_bars_after_breakout = input.int(0, "實體突破後忽略 K 棒數", minval=0, group=group_vegas, tooltip="收盤價突破通道後，必須經過 N 根 K 棒才開始判定回測。")
ema12_buffer_mult = input.float(0.0, "過濾線安全邊距 (ATR倍數)", step=0.1, minval=0.0, group=group_vegas, tooltip="過濾線離通道太近時重置判斷。設為 0 則僅在纏繞時重置。建議值 0.3~0.8。")

