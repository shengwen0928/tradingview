group_stats_set = "統計設定"
showStats = input.bool(title="顯示勝率統計表格", defval=true, group=group_stats_set)
statsPosition = input.string(title="統計表格位置", defval="右上", options=["右上","左上","中上","右中","左中","正中","右下","左下","中下"], group=group_stats_set)
statsTextSize = input.string(title="統計文字大小", defval="small", options=["tiny", "small", "normal", "large", "huge"], group=group_stats_set)

GRP_OBV_MA = "OBV 平滑處理"
maTypeInput = input.string("SMA + Bollinger Bands", "類型", options = ["None", "SMA", "SMA + Bollinger Bands", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group = GRP_OBV_MA)
maLengthInput = input.int(14, "長度", group = GRP_OBV_MA)
