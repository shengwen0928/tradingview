src5  = input.source(close, title="EMA 5 Source", group=GRP_EMA_MA)
src6  = input.source(close, title="EMA 6 Source", group=GRP_EMA_MA)
src7  = input.source(close, title="MA 1 Source", group=GRP_EMA_MA)
src8  = input.source(close, title="MA 2 Source", group=GRP_EMA_MA)
src9  = input.source(close, title="MA 3 Source", group=GRP_EMA_MA)
