longAtrLen = input.int(21, "長期 ATR 平滑長度 (EMA)", minval=1, group=GRP_ATR_FILTER)

GRP_VOL_EXP = "🥈 布林帶急遽擴張偵測 (Volatility Expansion)"
useVolExpMethod1 = input.bool(false, "啟用 方法一：寬度動能 (Momentum)", group=GRP_VOL_EXP)
useVolExpMethod2 = input.bool(false, "啟用 方法二：突破壓縮區 (Squeeze Break)", group=GRP_VOL_EXP)
useVolExpMethod3 = input.bool(false, "啟用 方法三：Z-Score 異常擴張 (Statistical)", group=GRP_VOL_EXP)
method2Lookback = input.int(50, "M2: 壓縮觀察長度", minval=10, group=GRP_VOL_EXP)
sqzMult = input.float(1.2, "M2: 壓縮定義 (Lowest * N)", step=0.1, group=GRP_VOL_EXP)
expMult = input.float(1.1, "M2: 爆發定義 (Width > Prev * N)", step=0.05, group=GRP_VOL_EXP)
zScoreThreshold = input.float(2.0, "Z-Score 閾值 (方法三)", step=0.1, group=GRP_VOL_EXP)
useIgnoreFirst = input.bool(false, "⚠️ 忽略擴張後的第一單", group=GRP_VOL_EXP)

GRP_SQZ = "🥉 價格與成交量壓縮過濾 (Squeeze Filters)"
usePrc = input.bool(false, "啟用 1. K線範圍壓縮 (Price Range)", group=GRP_SQZ)
prcLen = input.int(20, "1. 平均長度", group=GRP_SQZ)
prcThresh = input.float(0.7, "1. 壓縮閾值 (0.7 = 70%)", step=0.1, group=GRP_SQZ)
useKc = input.bool(false, "啟用 2. 凱特納通道收斂 (KC)", group=GRP_SQZ)
kcLen = input.int(20, "2. 長度", group=GRP_SQZ)
kcMult = input.float(1.5, "2. 倍數", group=GRP_SQZ)
useVolSqz = input.bool(false, "啟用 3. 成交量收斂 (Volume)", group=GRP_SQZ)
volSqzLen = input.int(20, "3. 平均長度", group=GRP_SQZ)
volSqzThresh = input.float(0.7, "3. 收斂閾值 (0.7 = 70%)", step=0.1, group=GRP_SQZ)
useDc = input.bool(false, "啟用 4. 唐奇安通道收縮 (Donchian)", group=GRP_SQZ)
dcLen = input.int(20, "4. 通道長度", group=GRP_SQZ)
dcSmaLen = input.int(50, "4. 平均寬度長度", group=GRP_SQZ)
useAdxSqz = input.bool(false, "啟用 5. ADX 趨勢強度 (ADX < N)", group=GRP_SQZ)
adxSqzLen = input.int(14, "5. ADX 長度", group=GRP_SQZ)
adxSqzThresh = input.int(20, "5. ADX 閾值", group=GRP_SQZ)
useRsiSqz = input.bool(false, "啟用 6. RSI 區間收斂 (40-60)", group=GRP_SQZ)
rsiSqzLen = input.int(14, "6. RSI 長度", group=GRP_SQZ)
rsiLower = input.int(40, "6. RSI 下限", group=GRP_SQZ)
rsiUpper = input.int(60, "6. RSI 上限", group=GRP_SQZ)
useStochSqz = input.bool(false, "啟用 7. 隨機指標區間收斂 (Stochastic 20-80)", group=GRP_SQZ)
stochSqzLen = input.int(14, "7. Stoch 長度", group=GRP_SQZ)
stochSqzLower = input.int(20, "7. Stoch 下限", group=GRP_SQZ)
stochSqzUpper = input.int(80, "7. Stoch 上限", group=GRP_SQZ)

GRP_EMA_MA = "7EMA_5MA 設定"
showEmaMa = input.bool(false, "顯示 7EMA/5MA", group=GRP_EMA_MA)
len1  = input.int(144, minval=1, title="EMA 1", group=GRP_EMA_MA)
len2  = input.int(169, minval=1, title="EMA 2", group=GRP_EMA_MA)
len3  = input.int(576, minval=1, title="EMA 3", group=GRP_EMA_MA)
len4  = input.int(676, minval=1, title="EMA 4", group=GRP_EMA_MA)
